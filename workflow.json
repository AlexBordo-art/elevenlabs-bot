    {
      "parameters": {
        "jsCode": "// Aggregate all agent rows into a single inline keyboard.\nconst rows = $input.all().map(i => i.json).filter(r => r.id);\nconst keyboard = rows.map(r => [{\n  text: '🎙 ' + (r.agent_name || r.elevenlabs_agent_id),\n  callback_data: 'select:' + r.id\n}]);\nkeyboard.push([{ text: '⬅ Назад', callback_data: 'menu' }]);\n\nconst text = rows.length\n  ? 'Твои агенты — выбери для редактирования:'\n  : 'У тебя пока нет агентов. Нажми «Добавить агента».';\n\nreturn [{ json: { text, keyboard } }];"
      },
